# Initialize git in your project
git init

# Add all files
git add .

# Commit your code
git commit -m "Initial KockZiLa-RPG commit"

# Rename branch to main (if needed)
git branch -M main

# Add remote (replace YOUR-USERNAME with your GitHub username)
git remote add origin https://github.com/manhuynhz-creator/kockzila-rpg.git

# Push to GitHub
git push -u origin main
